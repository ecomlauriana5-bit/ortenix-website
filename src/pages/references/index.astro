---
import BaseLayout from '../../layouts/BaseLayout.astro';
import References from '../../components/sections/References.astro';
import Contact from '../../components/sections/Contact.astro';

const caseStudies = [
  {
    sector: 'Offshore',
    color: '#00C2FF',
    icon: '⚓',
    client: 'Opérateur pétrolier international',
    problem: 'Détection de fissures sur nœuds tubulaires d\'une plateforme jacket en Mer du Nord. Décision d\'exploitation urgente requise.',
    approach: 'Analyse de fatigue hot-spot selon DNV-RP-C203. Modèle EF sous-marin raffiné, histogramme de chargement sur 20 ans, évaluation des seuils de propagation.',
    result: 'Durée de vie résiduelle de 8 ans confirmée. Plan d\'inspection adapté validé par DNV GL. Plateforme maintenue en exploitation sans shutdown.',
    duration: '6 semaines',
    norms: ['DNV-RP-C203', 'DNV-ST-0126', 'API RP 2A'],
  },
  {
    sector: 'Nucléaire',
    color: '#2ECC71',
    icon: '⚛️',
    client: 'Exploitant nucléaire français',
    problem: 'Remplacement d\'un composant ESPN Niveau N1 sur circuit primaire. Délai contraint par la fenêtre d\'arrêt de tranche.',
    approach: 'Note de calcul RCC-M complète : analyse de flexibilité, vérification des assemblages boulonnés, qualification sismique, dossier de conformité ESPN.',
    result: 'Qualification obtenue sans itération ASN. Mise en service respectant la date de redémarrage. Zéro non-conformité.',
    duration: '8 semaines',
    norms: ['RCC-M N1', 'ESPN', 'ASN RFS I.2.d'],
  },
  {
    sector: 'Naval',
    color: '#4A90D9',
    icon: '🚢',
    client: 'Chantier naval de défense',
    problem: 'Optimisation structurelle d\'une section de coque pour réduire la masse tout en maintenant la conformité BV Marine et les exigences STANAG.',
    approach: 'Optimisation topologique FEA, analyse de résistance longitudinale, vérification des critères de résistance au blast sous-marin selon STANAG 4154.',
    result: 'Réduction de masse de 12% sur la section considérée. Conformité BV Marine maintenue. Livré dans le cadre du programme naval en cours.',
    duration: '10 semaines',
    norms: ['BV Marine NR467', 'STANAG 4154', 'DNV GL'],
  },
  {
    sector: 'Énergie',
    color: '#C8A84B',
    icon: '⚡',
    client: 'Industriel équipements sous pression',
    problem: 'Conception d\'un échangeur de chaleur haute pression à plaques soumis à des cycles thermiques sévères. Qualification PED requise.',
    approach: 'Simulation CFD des profils de température, analyse thermo-mécanique ANSYS, vérification EN 13445-3 en fatigue thermique, dossier PED complet.',
    result: 'Conception validée du premier coup. Certification PED obtenue. Durée de vie garantie 25 ans en conditions nominales.',
    duration: '12 semaines',
    norms: ['EN 13445', 'PED 2014/68/UE', 'CODAP'],
  },
];
---

<BaseLayout
  title="Références — Cas clients et témoignages | Ortenix"
  description="Études de cas détaillées d'Ortenix : offshore, nucléaire, naval, énergie. Problèmes réels, approches rigoureuses, résultats mesurables. Références disponibles sous NDA."
  lang="fr"
>
  <!-- Hero -->
  <section class="relative py-24 bg-[var(--color-bg-primary)] overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 50% 50% at 30% 60%, rgba(0,194,255,0.05) 0%, transparent 70%);"></div>
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="flex items-center gap-3 mb-6">
        <span class="h-px w-12 bg-[var(--color-accent-cyan)]"></span>
        <a href="/" class="font-mono text-xs text-[var(--color-accent-cyan)] uppercase tracking-widest hover:underline">← Accueil</a>
      </div>
      <h1 class="font-display font-extrabold text-[var(--color-text-primary)] mb-4" style="font-size: clamp(2.5rem, 5vw, 5rem);">
        Nos <span class="text-gradient-cyan">références</span>
      </h1>
      <p class="text-[var(--color-text-secondary)] max-w-xl text-lg leading-relaxed">
        Des projets réels, dans des conditions réelles. Chaque cas client illustre notre approche : rigueur, conformité, résultat.
      </p>
      <p class="mt-3 font-mono text-xs text-[var(--color-text-muted)]">
        🔒 Noms anonymisés. Références nominatives disponibles sous NDA sur demande.
      </p>
    </div>
  </section>

  <!-- Case studies -->
  <section class="section-padding bg-[var(--color-bg-secondary)]">
    <div class="max-w-7xl mx-auto px-6">

      <!-- Sector filters -->
      <div class="flex flex-wrap gap-2 mb-10 fade-up" id="sector-filters">
        <button
          data-filter="all"
          class="filter-btn active font-mono text-xs px-4 py-2 rounded-lg border transition-colors"
        >
          Tous les secteurs
        </button>
        {[
          { label: 'Offshore', color: '#00C2FF' },
          { label: 'Nucléaire', color: '#2ECC71' },
          { label: 'Naval', color: '#4A90D9' },
          { label: 'Énergie', color: '#C8A84B' },
        ].map(f => (
          <button
            data-filter={f.label}
            class="filter-btn font-mono text-xs px-4 py-2 rounded-lg border border-[var(--color-bg-border)] text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] hover:border-current transition-colors"
            style={`--f-color: ${f.color};`}
          >
            {f.label}
          </button>
        ))}
      </div>

    <div class="space-y-8" id="case-studies-list">
      {caseStudies.map(cs => (
        <article
          class="fade-up bg-[var(--color-bg-card)] border border-[var(--color-bg-border)] rounded-2xl overflow-hidden hover:border-current transition-colors duration-300"
          style={`--cs-color: ${cs.color};`}
          data-sector={cs.sector}
        >
          <!-- Header -->
          <div class="flex items-center gap-4 px-8 py-5 border-b border-[var(--color-bg-border)]" style={`background: linear-gradient(to right, color-mix(in srgb, ${cs.color} 6%, transparent), transparent);`}>
            <span class="text-2xl">{cs.icon}</span>
            <div>
              <span class="font-mono text-xs uppercase tracking-widest" style={`color: ${cs.color};`}>{cs.sector}</span>
              <p class="font-display font-semibold text-[var(--color-text-primary)] text-sm">{cs.client}</p>
            </div>
            <div class="ml-auto flex items-center gap-2">
              <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span class="font-mono text-xs text-[var(--color-text-muted)]">{cs.duration}</span>
            </div>
          </div>

          <!-- 3-col content -->
          <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-[var(--color-bg-border)]">
            <div class="p-6">
              <p class="font-mono text-xs text-[var(--color-text-muted)] uppercase tracking-wide mb-3">Problème</p>
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{cs.problem}</p>
            </div>
            <div class="p-6">
              <p class="font-mono text-xs text-[var(--color-text-muted)] uppercase tracking-wide mb-3">Approche</p>
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{cs.approach}</p>
            </div>
            <div class="p-6">
              <p class="font-mono text-xs uppercase tracking-wide mb-3" style={`color: ${cs.color};`}>Résultat</p>
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{cs.result}</p>
            </div>
          </div>

          <!-- Norms footer -->
          <div class="flex flex-wrap items-center gap-2 px-8 py-4 border-t border-[var(--color-bg-border)] bg-[var(--color-bg-secondary)]">
            <span class="font-mono text-xs text-[var(--color-text-muted)] mr-2">Normes :</span>
            {cs.norms.map(n => (
              <span class="font-mono text-xs px-2 py-0.5 rounded bg-[var(--color-bg-card)] border border-[var(--color-bg-border)]" style={`color: ${cs.color};`}>{n}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
    </div>
  </section>

  <script>
    const filters = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('[data-sector]');

    filters.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter ?? 'all';

        // Update active button styles
        filters.forEach(b => {
          b.classList.remove('active');
          b.style.color = '';
          b.style.borderColor = '';
          b.style.background = '';
        });
        btn.classList.add('active');
        if (filter !== 'all') {
          const color = (btn as HTMLElement).style.getPropertyValue('--f-color');
          btn.style.color = color;
          btn.style.borderColor = color;
          btn.style.background = `color-mix(in srgb, ${color} 8%, transparent)`;
        } else {
          btn.style.color = 'var(--color-accent-cyan)';
          btn.style.borderColor = 'var(--color-accent-cyan)';
          btn.style.background = 'rgba(0,212,255,0.08)';
        }

        // Show/hide cards
        cards.forEach(card => {
          if (filter === 'all' || card.dataset.sector === filter) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });

    // Initialize "Tous" button style
    const allBtn = document.querySelector<HTMLButtonElement>('[data-filter="all"]');
    if (allBtn) {
      allBtn.style.color = 'var(--color-accent-cyan)';
      allBtn.style.borderColor = 'var(--color-accent-cyan)';
      allBtn.style.background = 'rgba(0,212,255,0.08)';
    }
  </script>

  <References lang="fr" />
  <Contact lang="fr" />
</BaseLayout>
