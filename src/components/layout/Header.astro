---
interface Props {
  lang?: string;
}
const { lang = 'fr' } = Astro.props;

const isFr = lang === 'fr';
const altLang = isFr ? 'en' : 'fr';
const altLangPath = isFr ? '/en' : '/';

const navLinks = isFr ? [
  { href: '/#expertises',  label: 'Expertises' },
  { href: '/#secteurs',    label: 'Secteurs' },
  { href: '/#offre',       label: 'Offre' },
  { href: '/#references',  label: 'Références' },
  { href: '/#equipe',      label: 'L\'équipe' },
  { href: '/#contact',     label: 'Contact' },
] : [
  { href: '/en/#expertises', label: 'Expertise' },
  { href: '/en/#sectors',    label: 'Sectors' },
  { href: '/en/#offer',      label: 'Offer' },
  { href: '/en/#references', label: 'References' },
  { href: '/en/#team',       label: 'Team' },
  { href: '/en/#contact',    label: 'Contact' },
];

const ctaLabel = isFr ? 'Devis 48h' : 'Quote 48h';
const contactHref = isFr ? '/#contact' : '/en/#contact';
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="header-inner max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href={isFr ? '/' : '/en'} class="flex items-center gap-2 group" aria-label="Ortenix — Accueil">
      <div class="logo-mark w-8 h-8 relative">
        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
          <rect x="2" y="2" width="28" height="28" rx="4" stroke="#00C2FF" stroke-width="1.5"/>
          <path d="M8 16 L16 8 L24 16 L16 24 Z" stroke="#00C2FF" stroke-width="1.5" fill="none"/>
          <circle cx="16" cy="16" r="3" fill="#00C2FF"/>
        </svg>
      </div>
      <span class="font-display font-700 text-xl tracking-tight text-[var(--color-text-primary)] group-hover:text-[var(--color-accent-cyan)] transition-colors">
        Ortenix
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex items-center gap-8" aria-label="Navigation principale">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="nav-link text-sm font-medium text-[var(--color-text-secondary)] hover:text-[var(--color-accent-cyan)] transition-colors relative after:absolute after:bottom-[-2px] after:left-0 after:w-0 after:h-[2px] after:bg-[var(--color-accent-cyan)] after:transition-all hover:after:w-full"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Right side -->
    <div class="flex items-center gap-3">
      <!-- Language toggle -->
      <a
        href={altLangPath}
        class="hidden sm:flex items-center gap-1 px-2.5 py-1 rounded border border-[var(--color-bg-border)] text-xs font-mono text-[var(--color-text-secondary)] hover:border-[var(--color-accent-cyan)] hover:text-[var(--color-accent-cyan)] transition-all"
        title={`Switch to ${altLang.toUpperCase()}`}
      >
        {altLang.toUpperCase()}
      </a>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        class="hidden sm:flex items-center justify-center w-8 h-8 rounded border border-[var(--color-bg-border)] text-[var(--color-text-secondary)] hover:border-[var(--color-accent-cyan)] hover:text-[var(--color-accent-cyan)] transition-all"
        aria-label="Toggle theme"
      >
        <svg id="icon-sun" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg id="icon-moon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <!-- CTA -->
      <a
        href={contactHref}
        class="hidden sm:inline-flex items-center gap-2 px-4 py-2 bg-[var(--color-accent-cyan)] text-[var(--color-bg-primary)] text-sm font-semibold rounded hover:bg-white transition-colors"
      >
        {ctaLabel}
      </a>

      <!-- Mobile burger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden flex flex-col gap-1.5 w-8 h-8 items-center justify-center"
        aria-label="Menu"
        aria-expanded="false"
      >
        <span class="burger-line w-5 h-0.5 bg-[var(--color-text-primary)] transition-all duration-300 origin-center"></span>
        <span class="burger-line w-5 h-0.5 bg-[var(--color-text-primary)] transition-all duration-300"></span>
        <span class="burger-line w-5 h-0.5 bg-[var(--color-text-primary)] transition-all duration-300 origin-center"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="lg:hidden hidden border-t border-[var(--color-bg-border)] backdrop-dark bg-[rgba(10,14,26,0.98)]"
  >
    <nav class="max-w-7xl mx-auto px-6 py-6 flex flex-col gap-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="mobile-nav-link text-[var(--color-text-secondary)] hover:text-[var(--color-accent-cyan)] font-medium py-2 border-b border-[var(--color-bg-border)] transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href={contactHref}
        class="mt-2 inline-flex items-center justify-center px-6 py-3 bg-[var(--color-accent-cyan)] text-[var(--color-bg-primary)] font-semibold rounded transition-colors hover:bg-white"
      >
        {ctaLabel}
      </a>
      <div class="flex items-center gap-3 mt-2">
        <a href={altLangPath} class="text-sm font-mono text-[var(--color-text-muted)] hover:text-[var(--color-accent-cyan)]">
          {altLang.toUpperCase()}
        </a>
      </div>
    </nav>
  </div>
</header>

<!-- Spacer to avoid content hidden behind fixed header -->
<div class="h-16"></div>

<script>
  // Sticky header style on scroll
  const header = document.getElementById('site-header');
  const headerInner = header?.querySelector('.header-inner');

  const updateHeader = () => {
    if (!header || !headerInner) return;
    if (window.scrollY > 50) {
      header.classList.add('backdrop-dark', 'bg-[rgba(10,14,26,0.92)]', 'border-b', 'border-[rgba(30,42,58,0.5)]');
    } else {
      header.classList.remove('backdrop-dark', 'bg-[rgba(10,14,26,0.92)]', 'border-b', 'border-[rgba(30,42,58,0.5)]');
    }
  };

  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();

  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const burgerLines = menuBtn?.querySelectorAll('.burger-line');

  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('hidden') === false;
    if (isOpen) {
      mobileMenu?.classList.add('hidden');
      menuBtn.setAttribute('aria-expanded', 'false');
      burgerLines?.[0]?.classList.remove('rotate-45', 'translate-y-2');
      burgerLines?.[1]?.classList.remove('opacity-0');
      burgerLines?.[2]?.classList.remove('-rotate-45', '-translate-y-2');
    } else {
      mobileMenu?.classList.remove('hidden');
      menuBtn.setAttribute('aria-expanded', 'true');
      burgerLines?.[0]?.classList.add('rotate-45', 'translate-y-2');
      burgerLines?.[1]?.classList.add('opacity-0');
      burgerLines?.[2]?.classList.add('-rotate-45', '-translate-y-2');
    }
  });

  // Close mobile menu on nav link click
  mobileMenu?.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
    });
  });

  // Theme toggle
  const themeToggle = document.getElementById('theme-toggle');
  const iconSun = document.getElementById('icon-sun');
  const iconMoon = document.getElementById('icon-moon');

  const applyTheme = (theme: string) => {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
    if (theme === 'light') {
      iconSun?.classList.remove('hidden');
      iconMoon?.classList.add('hidden');
    } else {
      iconSun?.classList.add('hidden');
      iconMoon?.classList.remove('hidden');
    }
  };

  // Init from saved preference
  const savedTheme = localStorage.getItem('theme') || 'dark';
  applyTheme(savedTheme);

  themeToggle?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme') || 'dark';
    applyTheme(current === 'dark' ? 'light' : 'dark');
  });
</script>
