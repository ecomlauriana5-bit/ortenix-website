---
interface Props {
  lang?: string;
}
const { lang = 'fr' } = Astro.props;
const isFr = lang === 'fr';
---

<footer class="border-t border-[var(--color-bg-border)] bg-[var(--color-bg-secondary)]">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">

      <!-- Brand -->
      <div class="lg:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-8 h-8">
            <rect x="2" y="2" width="28" height="28" rx="4" stroke="#00C2FF" stroke-width="1.5"/>
            <path d="M8 16 L16 8 L24 16 L16 24 Z" stroke="#00C2FF" stroke-width="1.5" fill="none"/>
            <circle cx="16" cy="16" r="3" fill="#00C2FF"/>
          </svg>
          <span class="font-display font-bold text-xl text-[var(--color-text-primary)]">Ortenix</span>
        </div>
        <p class="text-[var(--color-text-secondary)] text-sm leading-relaxed max-w-xs">
          {isFr
            ? 'Bureau d\'études en ingénierie de précision et IA industrielle. Offshore · Énergie · Naval · Nucléaire.'
            : 'Engineering firm specialized in precision engineering and industrial AI. Offshore · Energy · Naval · Nuclear.'}
        </p>
        <p class="mt-4 font-mono text-xs text-[var(--color-accent-cyan)] opacity-60">
          "We build certainty."
        </p>
      </div>

      <!-- Secteurs -->
      <div>
        <h3 class="font-display font-semibold text-sm text-[var(--color-text-primary)] uppercase tracking-widest mb-4">
          {isFr ? 'Secteurs' : 'Sectors'}
        </h3>
        <ul class="space-y-2">
          {[
            { label: 'Offshore', color: '#00C2FF' },
            { label: isFr ? 'Énergie' : 'Energy', color: '#C8A84B' },
            { label: 'Naval', color: '#4A90D9' },
            { label: isFr ? 'Nucléaire' : 'Nuclear', color: '#2ECC71' },
          ].map(s => (
            <li>
              <a href={`/#secteurs`} class="flex items-center gap-2 text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors">
                <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background:${s.color}`}></span>
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Liens -->
      <div>
        <h3 class="font-display font-semibold text-sm text-[var(--color-text-primary)] uppercase tracking-widest mb-4">
          {isFr ? 'Liens rapides' : 'Quick links'}
        </h3>
        <ul class="space-y-2">
          {[
            { href: '/#expertises', label: isFr ? 'Expertises' : 'Expertise' },
            { href: '/#offre',      label: isFr ? 'Notre offre' : 'Our offer' },
            { href: '/#references', label: isFr ? 'Références' : 'References' },
            { href: '/#equipe',     label: isFr ? 'L\'équipe' : 'Team' },
            { href: '/#contact',    label: 'Contact' },
          ].map(l => (
            <li>
              <a href={l.href} class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent-cyan)] transition-colors">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-[var(--color-bg-border)] flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-[var(--color-text-muted)]">
        &copy; {new Date().getFullYear()} Ortenix.
        {isFr ? 'Tous droits réservés.' : 'All rights reserved.'}
      </p>
      <div class="flex items-center gap-6">
        <span class="font-mono text-xs text-[var(--color-text-muted)] flex items-center gap-1.5">
          <svg class="w-3 h-3 text-[var(--color-accent-cyan)]" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
          </svg>
          {isFr ? 'NDA systématique' : 'Systematic NDA'}
        </span>
        <span class="font-mono text-xs text-[var(--color-text-muted)]">Netlify · Astro</span>
      </div>
    </div>
  </div>
</footer>
