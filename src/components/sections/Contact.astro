---
interface Props {
  lang?: string;
}
const { lang = 'fr' } = Astro.props;
const isFr = lang === 'fr';

const sectors = isFr
  ? ['Offshore', 'Énergie', 'Naval', 'Nucléaire', 'Autre']
  : ['Offshore', 'Energy', 'Naval', 'Nuclear', 'Other'];
---

<section class="section-padding bg-[var(--color-bg-primary)]" id="contact">
  <div class="max-w-7xl mx-auto px-6">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Left: Info -->
      <div class="fade-up">
        <div class="flex items-center gap-3 mb-4">
          <span class="h-px w-16 bg-[var(--color-accent-cyan)]"></span>
          <span class="font-mono text-xs text-[var(--color-accent-cyan)] uppercase tracking-widest">
            Contact
          </span>
        </div>
        <h2 class="font-display font-bold text-[var(--color-text-primary)] mb-4">
          {isFr ? 'Échange confidentiel' : 'Confidential exchange'}<br/>
          <span class="text-gradient-cyan">{isFr ? 'sous 48h' : 'within 48h'}</span>
        </h2>
        <p class="text-[var(--color-text-secondary)] leading-relaxed mb-8">
          {isFr
            ? 'Décrivez-nous votre besoin. Nous vous répondons dans les 48h avec une première approche technique et, si vous le souhaitez, un devis structuré.'
            : 'Describe your need. We respond within 48h with an initial technical approach and, if you wish, a structured quote.'}
        </p>

        <!-- Guarantees -->
        <div class="space-y-4">
          {[
            {
              icon: '🔒',
              title: isFr ? 'NDA systématique' : 'Systematic NDA',
              desc: isFr ? 'Sur demande, un NDA est signé avant tout échange technique.' : 'On request, an NDA is signed before any technical exchange.',
            },
            {
              icon: '⚡',
              title: isFr ? 'Réponse sous 48h' : 'Response within 48h',
              desc: isFr ? 'Premier retour technique garanti en moins de deux jours ouvrés.' : 'First technical response guaranteed within two business days.',
            },
            {
              icon: '🎯',
              title: isFr ? 'Expertise ciblée' : 'Targeted expertise',
              desc: isFr ? 'Mise en relation directe avec l\'ingénieur expert de votre secteur.' : 'Direct contact with the expert engineer for your sector.',
            },
          ].map(g => (
            <div class="flex gap-4">
              <span class="text-2xl flex-shrink-0">{g.icon}</span>
              <div>
                <p class="font-semibold text-[var(--color-text-primary)] text-sm">{g.title}</p>
                <p class="text-[var(--color-text-secondary)] text-sm">{g.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Calendly CTA -->
        <div class="mt-8 p-4 bg-[var(--color-bg-card)] border border-[var(--color-bg-border)] rounded-xl">
          <p class="text-sm text-[var(--color-text-secondary)] mb-3">
            {isFr ? 'Préférez un appel directement ?' : 'Prefer a direct call?'}
          </p>
          <a
            href="https://calendly.com/ortenix"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-accent-cyan)] hover:underline"
          >
            {isFr ? 'Prendre un RDV Calendly' : 'Book a Calendly appointment'}
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="fade-up">
        <form
          name="contact-ortenix"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="bg-[var(--color-bg-card)] border border-[var(--color-bg-border)] rounded-2xl p-8 space-y-5"
          id="contact-form"
        >
          <!-- Netlify hidden fields -->
          <input type="hidden" name="form-name" value="contact-ortenix" />
          <p class="hidden">
            <label>
              Don't fill this out if you're human:
              <input name="bot-field" />
            </label>
          </p>

          <!-- Name row -->
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="prenom" class="block text-xs font-mono text-[var(--color-text-muted)] mb-1.5">
                {isFr ? 'Prénom *' : 'First name *'}
              </label>
              <input
                type="text"
                id="prenom"
                name="prenom"
                required
                class="w-full px-4 py-2.5 bg-[var(--color-bg-secondary)] border border-[var(--color-bg-border)] rounded-lg text-sm text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] focus:border-[var(--color-accent-cyan)] focus:outline-none transition-colors"
                placeholder={isFr ? 'Jean' : 'John'}
              />
            </div>
            <div>
              <label for="nom" class="block text-xs font-mono text-[var(--color-text-muted)] mb-1.5">
                {isFr ? 'Nom *' : 'Last name *'}
              </label>
              <input
                type="text"
                id="nom"
                name="nom"
                required
                class="w-full px-4 py-2.5 bg-[var(--color-bg-secondary)] border border-[var(--color-bg-border)] rounded-lg text-sm text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] focus:border-[var(--color-accent-cyan)] focus:outline-none transition-colors"
                placeholder={isFr ? 'Dupont' : 'Smith'}
              />
            </div>
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block text-xs font-mono text-[var(--color-text-muted)] mb-1.5">
              Email *
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-2.5 bg-[var(--color-bg-secondary)] border border-[var(--color-bg-border)] rounded-lg text-sm text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] focus:border-[var(--color-accent-cyan)] focus:outline-none transition-colors"
              placeholder="jean.dupont@entreprise.fr"
            />
          </div>

          <!-- Company -->
          <div>
            <label for="societe" class="block text-xs font-mono text-[var(--color-text-muted)] mb-1.5">
              {isFr ? 'Société' : 'Company'}
            </label>
            <input
              type="text"
              id="societe"
              name="societe"
              class="w-full px-4 py-2.5 bg-[var(--color-bg-secondary)] border border-[var(--color-bg-border)] rounded-lg text-sm text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] focus:border-[var(--color-accent-cyan)] focus:outline-none transition-colors"
              placeholder={isFr ? 'TotalEnergies, Naval Group...' : 'TotalEnergies, Naval Group...'}
            />
          </div>

          <!-- Sector -->
          <div>
            <label for="secteur" class="block text-xs font-mono text-[var(--color-text-muted)] mb-1.5">
              {isFr ? 'Secteur concerné' : 'Relevant sector'}
            </label>
            <select
              id="secteur"
              name="secteur"
              class="w-full px-4 py-2.5 bg-[var(--color-bg-secondary)] border border-[var(--color-bg-border)] rounded-lg text-sm text-[var(--color-text-primary)] focus:border-[var(--color-accent-cyan)] focus:outline-none transition-colors cursor-pointer"
            >
              <option value="">{isFr ? '— Sélectionnez —' : '— Select —'}</option>
              {sectors.map(s => <option value={s}>{s}</option>)}
            </select>
          </div>

          <!-- Message -->
          <div>
            <label for="message" class="block text-xs font-mono text-[var(--color-text-muted)] mb-1.5">
              {isFr ? 'Votre besoin *' : 'Your need *'}
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows={5}
              class="w-full px-4 py-2.5 bg-[var(--color-bg-secondary)] border border-[var(--color-bg-border)] rounded-lg text-sm text-[var(--color-text-primary)] placeholder-[var(--color-text-muted)] focus:border-[var(--color-accent-cyan)] focus:outline-none transition-colors resize-none"
              placeholder={isFr
                ? 'Décrivez votre besoin : contexte technique, norme applicable, délai souhaité...'
                : 'Describe your need: technical context, applicable standard, desired timeline...'}
            ></textarea>
          </div>

          <!-- NDA mention -->
          <div class="flex items-start gap-3 p-4 bg-[var(--color-bg-secondary)] rounded-lg border border-[var(--color-bg-border)]">
            <svg class="w-4 h-4 text-[var(--color-accent-cyan)] flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd"/>
            </svg>
            <p class="text-xs text-[var(--color-text-muted)] font-mono">
              {isFr
                ? 'NDA systématique sur demande — Confidentialité garantie. Vos informations ne sont jamais partagées.'
                : 'Systematic NDA on request — Guaranteed confidentiality. Your information is never shared.'}
            </p>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            class="w-full inline-flex items-center justify-center gap-2 px-6 py-4 bg-[var(--color-accent-cyan)] text-[var(--color-bg-primary)] font-semibold rounded-lg hover:bg-white transition-colors text-sm"
          >
            {isFr ? 'Envoyer ma demande' : 'Send my request'}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
          </button>

          <!-- Success message (hidden) -->
          <div id="form-success" class="hidden p-4 bg-[rgba(46,204,113,0.1)] border border-[rgba(46,204,113,0.3)] rounded-lg text-center">
            <p class="text-sm text-[#2ECC71] font-medium">
              {isFr ? '✓ Message envoyé ! Nous vous répondrons sous 48h.' : '✓ Message sent! We will respond within 48h.'}
            </p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);

    try {
      await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(data as any).toString(),
      });
      form.reset();
      successMsg?.classList.remove('hidden');
    } catch {
      // On Netlify this is handled server-side; fallback to native submit
      form.submit();
    }
  });
</script>
