---
interface Props {
  lang?: string;
}
const { lang = 'fr' } = Astro.props;
const isFr = lang === 'fr';

const founder = {
  name: 'Lauriana',
  role: isFr ? 'Fondatrice & Ingénieure Senior · FEA & Simulation' : 'Founder & Senior Engineer · FEA & Simulation',
  expertise: ['Abaqus', 'ANSYS', 'NASTRAN', 'FEMAP', 'SACS', 'Stead Pro'],
  quote: isFr
    ? '"Ortenix est né d\'une conviction : l\'ingénierie de précision doit être accessible, rigoureuse et orientée résultats — pas juste conforme."'
    : '"Ortenix was born from a conviction: precision engineering must be accessible, rigorous and results-oriented — not just compliant."',
  initials: 'L',
  color: '#00D4FF',
  isFounder: true,
};

const team = [
  {
    name: 'Alexandre Moreau',
    role: isFr ? 'Directeur technique · FEA & Structures' : 'Technical Director · FEA & Structures',
    expertise: ['ANSYS', 'ABAQUS', 'DNV', 'API'],
    quote: isFr
      ? '"La certitude ne s\'improvise pas. Elle se construit calcul après calcul."'
      : '"Certainty is not improvised. It is built calculation by calculation."',
    initials: 'AM',
    color: '#00C2FF',
  },
  {
    name: 'Sophie Renaud',
    role: isFr ? 'Ingénieure Senior · CFD & Thermique' : 'Senior Engineer · CFD & Thermal',
    expertise: ['ANSYS Fluent', 'OpenFOAM', 'STAR-CCM+'],
    quote: isFr
      ? '"Simuler le réel pour le maîtriser avant qu\'il ne se produise."'
      : '"Simulate reality to master it before it happens."',
    initials: 'SR',
    color: '#0066CC',
  },
  {
    name: 'Thomas Duval',
    role: isFr ? 'Ingénieur · Nucléaire & Conformité' : 'Engineer · Nuclear & Compliance',
    expertise: ['RCC-M', 'ASME III', 'RSE-M', 'ESPN'],
    quote: isFr
      ? '"Dans le nucléaire, la rigueur n\'est pas une option, c\'est la fondation."'
      : '"In nuclear, rigor is not an option, it is the foundation."',
    initials: 'TD',
    color: '#2ECC71',
  },
  {
    name: 'Clara Fontaine',
    role: isFr ? 'Data Scientist · IA Industrielle' : 'Data Scientist · Industrial AI',
    expertise: ['Python', 'TensorFlow', 'MATLAB', 'Scikit-learn'],
    quote: isFr
      ? '"Les données racontent une histoire. Notre rôle est de la déchiffrer avant la panne."'
      : '"Data tells a story. Our role is to decode it before the breakdown."',
    initials: 'CF',
    color: '#A855F7',
  },
];
---

<section class="section-padding bg-[var(--color-bg-secondary)]" id="equipe">
  <div class="max-w-7xl mx-auto px-6">

    <!-- Header -->
    <div class="mb-16 fade-up">
      <div class="flex items-center gap-3 mb-4">
        <span class="h-px w-16 bg-[var(--color-accent-cyan)]"></span>
        <span class="font-mono text-xs text-[var(--color-accent-cyan)] uppercase tracking-widest">
          {isFr ? 'L\'équipe' : 'The team'}
        </span>
      </div>
      <h2 class="font-display font-bold text-[var(--color-text-primary)]">
        {isFr ? 'Des ingénieurs' : 'Engineers'}<br/>
        <span class="text-gradient-cyan">{isFr ? 'de terrain' : 'with field experience'}</span>
      </h2>
      <p class="mt-4 text-[var(--color-text-secondary)] max-w-xl">
        {isFr
          ? 'Pas de juniors en façade. Des ingénieurs expérimentés qui connaissent vos normes, vos contraintes et vos enjeux.'
          : 'No junior engineers in front. Experienced engineers who know your standards, your constraints and your challenges.'}
      </p>
    </div>

    <!-- Founder card — full width -->
    <div class="mb-8 fade-up">
      <div
        class="group relative bg-[var(--color-bg-card)] border border-[var(--color-bg-border)] rounded-2xl p-8 hover:border-[var(--color-accent-cyan)] transition-all duration-300 flex flex-col md:flex-row gap-8 items-start"
        style="border-top: 3px solid #00D4FF;"
      >
        <!-- Avatar + badge -->
        <div class="flex-shrink-0">
          <div class="w-20 h-20 rounded-2xl flex items-center justify-center text-2xl font-bold border border-[rgba(0,212,255,0.3)]" style="background: rgba(0,212,255,0.1); color: #00D4FF;">
            {founder.initials}
          </div>
          <span class="mt-3 flex items-center gap-1.5 font-mono text-xs px-2.5 py-1 rounded-full border border-[rgba(0,212,255,0.3)] text-[var(--color-accent-cyan)]" style="background: rgba(0,212,255,0.06);">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
            </svg>
            {isFr ? 'Fondatrice' : 'Founder'}
          </span>
        </div>

        <!-- Info -->
        <div class="flex-1">
          <h3 class="font-display font-bold text-[var(--color-text-primary)] text-xl mb-1">{founder.name}</h3>
          <p class="text-xs text-[var(--color-text-muted)] font-mono leading-tight mb-4">{founder.role}</p>
          <p class="text-sm text-[var(--color-text-secondary)] italic leading-relaxed mb-6 max-w-2xl">{founder.quote}</p>
          <div class="flex flex-wrap gap-1.5">
            {founder.expertise.map(skill => (
              <span class="font-mono text-xs px-2.5 py-1 rounded-lg bg-[var(--color-bg-secondary)] border border-[var(--color-bg-border)] text-[var(--color-accent-cyan)]">
                {skill}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Team grid -->
    <div class="stagger-container grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
      {team.map(member => (
        <div
          class="stagger-item group relative bg-[var(--color-bg-card)] border border-[var(--color-bg-border)] rounded-xl p-6 hover:border-current transition-all duration-300 hover:-translate-y-1 flex flex-col"
          style={`--m-color: ${member.color};`}
        >
          <!-- Avatar -->
          <div class="w-16 h-16 rounded-xl flex items-center justify-center text-xl font-bold mb-5 border border-[var(--color-bg-border)] group-hover:border-current transition-colors" style={`background: color-mix(in srgb, ${member.color} 12%, var(--color-bg-secondary)); color: ${member.color};`}>
            {member.initials}
          </div>

          <!-- Info -->
          <h3 class="font-display font-semibold text-[var(--color-text-primary)] mb-1 group-hover:text-[var(--m-color)] transition-colors">
            {member.name}
          </h3>
          <p class="text-xs text-[var(--color-text-muted)] font-mono leading-tight mb-4">
            {member.role}
          </p>

          <!-- Quote -->
          <p class="text-sm text-[var(--color-text-secondary)] italic leading-relaxed flex-1 mb-5">
            {member.quote}
          </p>

          <!-- Skills -->
          <div class="flex flex-wrap gap-1.5">
            {member.expertise.map(skill => (
              <span class="font-mono text-xs px-2 py-0.5 rounded bg-[var(--color-bg-secondary)] border border-[var(--color-bg-border)] text-[var(--color-text-muted)]">
                {skill}
              </span>
            ))}
          </div>

          <!-- Top border on hover -->
          <div class="absolute top-0 left-0 right-0 h-[2px] rounded-t-xl opacity-0 group-hover:opacity-100 transition-opacity" style={`background: ${member.color};`}></div>
        </div>
      ))}
    </div>
  </div>
</section>
