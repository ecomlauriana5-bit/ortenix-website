---
---

<canvas
  id="fea-canvas"
  class="absolute inset-0 w-full h-full pointer-events-none opacity-30"
  aria-hidden="true"
></canvas>

<script>
  const canvas = document.getElementById('fea-canvas') as HTMLCanvasElement;
  if (!canvas) throw new Error('Canvas not found');
  const ctx = canvas.getContext('2d')!;

  let W = 0, H = 0;
  let nodes: { x: number; y: number; vx: number; vy: number }[] = [];
  let animId: number;

  const NODE_COUNT = 60;
  const LINK_DIST = 140;
  const CYAN = 'rgba(0,194,255,';
  const BLUE = 'rgba(0,102,204,';

  const resize = () => {
    W = canvas.offsetWidth;
    H = canvas.offsetHeight;
    canvas.width = W * devicePixelRatio;
    canvas.height = H * devicePixelRatio;
    ctx.scale(devicePixelRatio, devicePixelRatio);
    initNodes();
  };

  const initNodes = () => {
    nodes = Array.from({ length: NODE_COUNT }, () => ({
      x: Math.random() * W,
      y: Math.random() * H,
      vx: (Math.random() - 0.5) * 0.4,
      vy: (Math.random() - 0.5) * 0.4,
    }));
  };

  const draw = () => {
    ctx.clearRect(0, 0, W, H);

    // Update positions
    nodes.forEach(n => {
      n.x += n.vx;
      n.y += n.vy;
      if (n.x < 0 || n.x > W) n.vx *= -1;
      if (n.y < 0 || n.y > H) n.vy *= -1;
    });

    // Draw edges (triangulated mesh look)
    for (let i = 0; i < nodes.length; i++) {
      for (let j = i + 1; j < nodes.length; j++) {
        const dx = nodes[i].x - nodes[j].x;
        const dy = nodes[i].y - nodes[j].y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < LINK_DIST) {
          const alpha = (1 - dist / LINK_DIST) * 0.5;
          ctx.beginPath();
          ctx.strokeStyle = `${CYAN}${alpha})`;
          ctx.lineWidth = 0.5;
          ctx.moveTo(nodes[i].x, nodes[i].y);
          ctx.lineTo(nodes[j].x, nodes[j].y);
          ctx.stroke();

          // Draw triangle fill for close nodes
          for (let k = j + 1; k < nodes.length; k++) {
            const dx2 = nodes[i].x - nodes[k].x;
            const dy2 = nodes[i].y - nodes[k].y;
            const dx3 = nodes[j].x - nodes[k].x;
            const dy3 = nodes[j].y - nodes[k].y;
            const d2 = Math.sqrt(dx2 * dx2 + dy2 * dy2);
            const d3 = Math.sqrt(dx3 * dx3 + dy3 * dy3);
            if (d2 < LINK_DIST && d3 < LINK_DIST) {
              const triAlpha = Math.min(alpha, (1 - d2 / LINK_DIST), (1 - d3 / LINK_DIST)) * 0.08;
              ctx.beginPath();
              ctx.fillStyle = `${BLUE}${triAlpha})`;
              ctx.moveTo(nodes[i].x, nodes[i].y);
              ctx.lineTo(nodes[j].x, nodes[j].y);
              ctx.lineTo(nodes[k].x, nodes[k].y);
              ctx.closePath();
              ctx.fill();
            }
          }
        }
      }
    }

    // Draw nodes
    nodes.forEach(n => {
      ctx.beginPath();
      ctx.arc(n.x, n.y, 1.5, 0, Math.PI * 2);
      ctx.fillStyle = `${CYAN}0.5)`;
      ctx.fill();
    });

    animId = requestAnimationFrame(draw);
  };

  const ro = new ResizeObserver(resize);
  ro.observe(canvas);
  resize();
  draw();

  // Respect reduced motion
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    cancelAnimationFrame(animId);
    ctx.clearRect(0, 0, W, H);
  }
</script>
