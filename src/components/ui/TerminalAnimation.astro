---
interface Props {
  lines?: string[];
}

const defaultLines = [
  '> Initializing FEA solver... [OFFSHORE_STRUCT_001]',
  '> Loading mesh — 847,392 elements',
  '> Checking DNV-ST-0126 compliance...',
  '> Applying boundary conditions: wave load case 7',
  '> Running nonlinear static analysis...',
  '> Mesh quality: 98.7% elements within tolerance',
  '> Von Mises stress peak: 287.4 MPa',
  '> ✓ Analysis complete — Factor of Safety: 3.42',
  '> Generating NDA report... CONFIDENTIAL',
];

const { lines = defaultLines } = Astro.props;
---

<div
  class="terminal-window bg-[#060A14] border border-[var(--color-bg-border)] rounded-xl overflow-hidden font-mono text-sm"
  role="region"
  aria-label="Terminal technique Ortenix"
>
  <!-- Title bar -->
  <div class="flex items-center gap-2 px-4 py-3 bg-[var(--color-bg-card)] border-b border-[var(--color-bg-border)]">
    <span class="w-3 h-3 rounded-full bg-[#FF5F57]"></span>
    <span class="w-3 h-3 rounded-full bg-[#FEBC2E]"></span>
    <span class="w-3 h-3 rounded-full bg-[#28C840]"></span>
    <span class="ml-4 text-xs text-[var(--color-text-muted)]">ortenix-fea — analysis.sh</span>
  </div>

  <!-- Terminal body -->
  <div class="p-6 min-h-[280px] space-y-1" id="terminal-body" aria-live="polite">
    <!-- Lines will be typed by JS -->
  </div>
</div>

<script define:vars={{ lines }}>
  const body = document.getElementById('terminal-body');
  if (!body) return;

  const CHAR_SPEED = 30;   // ms per char
  const LINE_PAUSE = 400;  // ms between lines

  let lineIndex = 0;
  let charIndex = 0;
  let currentLineEl = null;

  const colors = (line) => {
    if (line.startsWith('> ✓')) return '#2ECC71';
    if (line.includes('CONFIDENTIAL')) return '#C8A84B';
    if (line.startsWith('> Loading') || line.startsWith('> Init')) return '#00C2FF';
    if (line.startsWith('> ')) return '#8B9DC3';
    return '#F0F4FF';
  };

  const typeNextChar = () => {
    if (lineIndex >= lines.length) {
      // Restart after pause
      setTimeout(() => {
        body.innerHTML = '';
        lineIndex = 0;
        charIndex = 0;
        currentLineEl = null;
        typeNextChar();
      }, 3000);
      return;
    }

    const line = lines[lineIndex];

    if (charIndex === 0) {
      currentLineEl = document.createElement('p');
      currentLineEl.style.color = colors(line);
      currentLineEl.style.whiteSpace = 'pre';
      // Add cursor
      const cursor = document.createElement('span');
      cursor.className = 'cursor-blink';
      cursor.textContent = '█';
      cursor.style.color = '#00C2FF';
      currentLineEl.appendChild(cursor);
      body.appendChild(currentLineEl);
    }

    if (charIndex < line.length) {
      // Remove cursor, add char, re-add cursor
      currentLineEl.innerHTML = '';
      const text = document.createTextNode(line.slice(0, charIndex + 1));
      currentLineEl.appendChild(text);
      const cursor = document.createElement('span');
      cursor.className = 'cursor-blink';
      cursor.textContent = '█';
      cursor.style.color = '#00C2FF';
      cursor.style.fontSize = '0.85em';
      currentLineEl.appendChild(cursor);
      charIndex++;
      setTimeout(typeNextChar, CHAR_SPEED);
    } else {
      // Line complete — remove cursor, move to next line
      currentLineEl.innerHTML = '';
      currentLineEl.appendChild(document.createTextNode(line));
      lineIndex++;
      charIndex = 0;
      currentLineEl = null;
      setTimeout(typeNextChar, LINE_PAUSE);
    }
  };

  // Start when visible
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    lines.forEach(line => {
      const p = document.createElement('p');
      p.style.color = colors(line);
      p.textContent = line;
      body.appendChild(p);
    });
  } else {
    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        typeNextChar();
        observer.disconnect();
      }
    }, { threshold: 0.3 });
    observer.observe(body);
  }
</script>
